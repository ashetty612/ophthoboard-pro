        {
          "id": "opt-5",
          "caseNumber": 5,
          "source": "",
          "title": "How do you help a child keep glasses on?",
          "subspecialty": "Optics",
          "presentation": "How do you help a child keep glasses on?",
          "imageFile": null,
          "imageFiles": [],
          "photoDescription": "",
          "questions": [
            {
              "number": 1,
              "question": "Discussion",
              "answer": "\u25cf Check proper refraction\n\u25cf Ensure proper fit (fit around ears, nasal bridge) \u2013 pediatric frames\no Elastic straps\no Temple frames that curl around ears\n\u25cf Check optical centers positioned on visual axis\n\u25cf If hyperope may try short trial of cycloplegic to help patient appreciate glasses\n\u25cf Positive reinforcement \u2013 associate wearing glasses with doing something fun, fun frames\n\u25cf Wrist splints for extreme cases",
